const multer = require('multer');
// Thêm 2 thư viện này vào để xử lý file tải lên
const multer = require('multer');
const path = require('path');

// Cấu hình chỗ lưu ảnh và đổi tên ảnh để không bị trùng
const storage = multer.diskStorage({
    destination: function (req, file, cb) { 
        cb(null, 'public/uploads/') // Nhớ phải có thư mục này nha
    },
    filename: function (req, file, cb) { 
        // Gắn thêm ngày giờ hiện tại vào trước tên ảnh để tránh trùng lặp
        cb(null, Date.now() + '-' + file.originalname) 
    }
});
const upload = multer({ storage: storage });
const storage = multer.diskStorage({
    destination: function (req, file, cb) { cb(null, 'public/uploads/') },
    filename: function (req, file, cb) { cb(null, Date.now() + '-' + file.originalname) }
});
const upload = multer({ storage: storage });

// Sửa lại route /scan-bill để trả về đường dẫn ảnh
router.post('/scan-bill', upload.single('billImage'), async (req, res) => {
    try {
        // Nếu không có file gửi lên thì báo lỗi
        if (!req.file) {
            return res.status(400).json({ success: false, message: 'Chưa có ảnh' });
        }

        // --- CHỖ NÀY NÝ GIỮ NGUYÊN LOGIC GỌI TESSERACT OCR CỦA NÝ ---
        // Ví dụ AI đọc được số tiền là 150000
        const maxAmount = 150000; 

        // Lấy cái tên file vừa lưu để làm đường link
        // Mốt ra frontend nó sẽ là: <img src="/uploads/168123456-bill.jpg">
        const imagePath = '/uploads/' + req.file.filename; 

        // Trả kết quả về cho giao diện (bao gồm cả số tiền và link ảnh)
        res.json({ 
            success: true, 
            suggestedAmount: maxAmount, 
            imageUrl: imagePath // <-- Mấu chốt là gửi cái này về!
        });

    } catch (error) {
        console.error("Lỗi quét OCR:", error);
        res.status(500).json({ success: false });
    }
});