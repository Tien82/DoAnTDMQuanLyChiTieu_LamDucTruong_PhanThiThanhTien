<%- include('../partials/header') %>

    <div class="container mt-4">
        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="card p-4 border-0 shadow-sm h-100"
                    style="border-radius: 24px; background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);">
                    <h2 class="fw-bold">Chào <span class="text-primary">
                            <%= user %>
                        </span>! 👋</h2>
                    <p class="text-muted">Hôm nay ný muốn ghi chép chi tiêu bằng cách nào?</p>

                    <div class="mt-4 p-3 bg-white rounded-4 shadow-sm border border-light">
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="fw-semibold text-secondary">Hạn mức tháng này</span>
                            <span class="<%= phanTram > 80 ? 'text-danger' : 'text-primary' %> fw-bold">
                                <%= phanTram %>%
                            </span>
                        </div>
                        <div class="progress" style="height: 10px; border-radius: 10px; background-color: #e9ecef;">
                            <div class="progress-bar <%= phanTram > 80 ? 'bg-danger' : 'bg-primary' %> progress-bar-striped progress-bar-animated"
                                style="width: <%= phanTram %>%"></div>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <small class="text-muted" style="font-size: 0.75rem;">
                                Đã tiêu: <strong>
                                    <%= tongChiTieu.toLocaleString('vi-VN') %>đ
                                </strong>
                            </small>
                            <small class="text-muted" style="font-size: 0.75rem;">
                                Hạn mức: <%= hanMuc.toLocaleString('vi-VN') %>đ
                            </small>
                        </div>

                        <% if (typeof dataAI !=='undefined' ) { %>
                            <div class="mt-3 p-3 rounded-3"
                                style="background-color: <%= dataAI.mauSac %>15; border-left: 4px solid <%= dataAI.mauSac %>;">
                                <div class="d-flex align-items-center">
                                    <div class="me-2"><i class="bi bi-robot fs-4"
                                            style="color: <%= dataAI.mauSac %>;"></i></div>
                                    <div>
                                        <small class="fw-bold d-block" style="color: <%= dataAI.mauSac %>;">Trợ lý AI
                                            khuyên:</small>
                                        <small class="text-dark">
                                            <%= dataAI.noiDung %>
                                        </small>
                                    </div>
                                </div>
                                <div class="mt-2 text-end">
                                    <small class="fw-bold text-primary" style="font-size: 0.7rem;">
                                        <%= dataAI.phuongAn %>
                                    </small>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="row g-3 h-100">
                    <div class="col-4">
                        <div class="card border-0 shadow-sm h-100 text-center p-3 btn-bento bg-primary text-white"
                            id="btn-voice" style="cursor: pointer;">
                            <div class="icon-circle mb-2"><i class="bi bi-mic-fill fs-3"></i></div>
                            <span class="fw-bold small d-block">GIỌNG NÓI</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <label for="ocr-upload"
                            class="card border-0 shadow-sm h-100 text-center p-3 btn-bento bg-success text-white mb-0"
                            style="cursor: pointer;">
                            <div class="icon-circle mb-2"><i class="bi bi-camera-fill fs-3"></i></div>
                            <span class="fw-bold small d-block">QUÉT BILL</span>
                            <input type="file" id="ocr-upload" hidden accept="image/*">
                        </label>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 shadow-sm h-100 text-center p-3 btn-bento bg-info text-white"
                            data-bs-toggle="modal" data-bs-target="#manualModal" style="cursor: pointer;">
                            <div class="icon-circle mb-2"><i class="bi bi-pencil-square fs-3"></i></div>
                            <span class="fw-bold small d-block">NHẬP TAY</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card p-4 border-0 shadow-sm h-100 rounded-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>Thu nhập & Chi tiêu
                        tháng này</h5>
                    <div class="chart-container mb-3" style="position: relative; height:250px;">
                        <canvas id="mainMonthlyChart"></canvas>
                    </div>
                    <div class="text-center">
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold" data-bs-toggle="modal"
                            data-bs-target="#detailChartModal">
                            <i class="bi bi-search me-1"></i> Xem chi tiết phân tích
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-4 border-0 shadow-sm h-100 rounded-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-geo-alt-fill me-2 text-danger"></i>Vị trí gần đây</h5>
                    <div id="map" style="height: 300px; border-radius: 16px; background-color: #f8f9fa;" class="border">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="detailChartModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 28px;">
                <div class="modal-header border-0 px-4 pt-4 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-bar-chart-line-fill me-2"></i>Phân tích chi tiết
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6 text-center">
                            <h6 class="fw-bold text-muted mb-3 text-uppercase" style="font-size: 0.75rem;">Cơ cấu hạng
                                mục chi tiêu</h6>
                            <div style="height: 250px;"><canvas id="detailPieChart"></canvas></div>
                        </div>
                        <div class="col-md-6 text-center">
                            <h6 class="fw-bold text-muted mb-3 text-uppercase" style="font-size: 0.75rem;">Tương quan
                                Thu nhập - Chi tiêu</h6>
                            <div style="height: 250px;"><canvas id="detailBarChart"></canvas></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="manualModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 24px;">
                <div class="modal-header border-0 px-4 pt-4">
                    <h5 class="modal-title fw-bold">Thêm giao dịch mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form action="/dashboard/input/manual" method="POST">
                        <input type="hidden" name="lat" id="latInput">
                        <input type="hidden" name="lng" id="lngInput">

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Số tiền (VNĐ)</label>
                            <input type="number" name="soTien"
                                class="form-control form-control-lg border-0 bg-light rounded-3" placeholder="0"
                                required>
                        </div>

                        <div class="mb-3 position-relative">
                            <label class="form-label small fw-bold text-muted text-uppercase">Tên địa điểm / Quán
                                ăn</label>
                            <div class="input-group">
                                <input type="text" name="tenQuan" id="searchInput"
                                    class="form-control border-0 bg-light py-2 rounded-start-3"
                                    placeholder="Ví dụ: Siêu thị Mega">
                                <button class="btn btn-primary fw-bold" type="button" id="btnSearchMap">
                                    <i class="bi bi-search"></i> Tìm trên Map
                                </button>
                            </div>
                            <ul id="searchResults" class="list-group position-absolute w-100 shadow mt-1"
                                style="z-index: 1050; display: none; max-height: 200px; overflow-y: auto;"></ul>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Hạng mục</label>
                                <select name="hangMuc" class="form-select border-0 bg-light py-2">
                                    <option value="Ăn uống">🍜 Ăn uống</option>
                                    <option value="Di chuyển">🚗 Di chuyển</option>
                                    <option value="Mua sắm">🛍️ Mua sắm</option>
                                    <option value="Giải trí">🎮 Giải trí</option>
                                    <option value="Khác">⚙️ Khác</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Loại</label>
                                <select name="loai" class="form-select border-0 bg-light py-2">
                                    <option value="chi">Chi tiêu (-)</option>
                                    <option value="thu">Thu nhập (+)</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Ghi chú</label>
                            <input type="text" name="ghiChu" class="form-control border-0 bg-light py-2"
                                placeholder="Ný tiêu vào việc gì thế?">
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill shadow-sm">LƯU GIAO
                            DỊCH</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

