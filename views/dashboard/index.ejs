<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container mt-4">
    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card p-4 border-0 shadow-sm h-100" style="border-radius: 24px; background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);">
                <h2 class="fw-bold">Chào <span class="text-primary"><%= user %></span>! 👋</h2>
                <p class="text-muted">Hôm nay bạn muốn ghi chép chi tiêu bằng cách nào?</p>

                <div class="mt-4 p-3 bg-white rounded-4 shadow-sm border border-light">
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="fw-semibold text-secondary">Hạn mức tháng này</span>
                        <span class="<%= phanTram > 80 ? 'text-danger' : 'text-primary' %> fw-bold"><%= phanTram %>%</span>
                    </div>
                    <div class="progress" style="height: 10px; border-radius: 10px; background-color: #e9ecef;">
                        <div class="progress-bar <%= phanTram > 80 ? 'bg-danger' : 'bg-primary' %> progress-bar-striped progress-bar-animated" style="width: <%= phanTram %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <small class="text-muted" style="font-size: 0.75rem;">Đã tiêu: <strong><%= tongChiTieu.toLocaleString('vi-VN') %>đ</strong></small>
                        <small class="text-muted" style="font-size: 0.75rem;">Hạn mức: <%= hanMuc.toLocaleString('vi-VN') %>đ</small>
                    </div>

                    <% if (typeof dataAI !== 'undefined') { %>
                    <div class="mt-3 p-3 rounded-3" style="background-color: <%= dataAI.mauSac %>15; border-left: 4px solid <%= dataAI.mauSac %>;">
                        <div class="d-flex align-items-center">
                            <div class="me-2"><i class="bi bi-robot fs-4" style="color: <%= dataAI.mauSac %>;"></i></div>
                            <div><small class="fw-bold d-block" style="color: <%= dataAI.mauSac %>;">Trợ lý AI khuyên:</small><small class="text-dark"><%= dataAI.noiDung %></small></div>
                        </div>
                        <div class="mt-2 text-end"><small class="fw-bold text-primary" style="font-size: 0.7rem;"><%= dataAI.phuongAn %></small></div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="row g-3 h-100">
                <div class="col-4">
                    <div class="card border-0 shadow-sm h-100 text-center p-3 btn-bento bg-primary text-white" id="btn-voice" style="cursor: pointer;">
                        <div class="icon-circle mb-2"><i class="bi bi-mic-fill fs-3"></i></div>
                        <span class="fw-bold small d-block">GIỌNG NÓI</span>
                    </div>
                </div>
                <div class="col-4">
                    <label for="ocr-upload" class="card border-0 shadow-sm h-100 text-center p-3 btn-bento bg-success text-white mb-0" style="cursor: pointer;">
                        <div class="icon-circle mb-2"><i class="bi bi-camera-fill fs-3"></i></div>
                        <span class="fw-bold small d-block">QUÉT BILL</span>
                        <input type="file" id="ocr-upload" hidden accept="image/*">
                    </label>
                </div>
                <div class="col-4">
                    <div class="card border-0 shadow-sm h-100 text-center p-3 btn-bento bg-info text-white" data-bs-toggle="modal" data-bs-target="#manualModal" style="cursor: pointer;">
                        <div class="icon-circle mb-2"><i class="bi bi-pencil-square fs-3"></i></div>
                        <span class="fw-bold small d-block">NHẬP TAY</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card p-4 border-0 shadow-sm h-100 rounded-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>Thu nhập & Chi tiêu tháng này</h5>
                <div class="chart-container mb-3" style="position: relative; height:250px;"><canvas id="mainMonthlyChart"></canvas></div>
                <div class="text-center">
                    <button class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#detailChartModal"><i class="bi bi-search me-1"></i> Xem chi tiết phân tích</button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4 border-0 shadow-sm h-100 rounded-4">
                <h5 class="fw-bold mb-4"><i class="bi bi-geo-alt-fill me-2 text-danger"></i>Vị trí gần đây</h5>
                <div id="map" style="height: 300px; border-radius: 16px; background-color: #f8f9fa;" class="border"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailChartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow" style="border-radius: 28px; background-color: #f4f6f9;">
            <div class="modal-header border-0 px-4 pt-4 pb-2 bg-white rounded-top-4">
                <h5 class="modal-title fw-bold"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Phân tích tài chính</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="card border-0 rounded-4 shadow-sm mb-4 p-3 bg-white">
                    <h6 class="fw-bold mb-3 text-center">Biến động chi tiêu 6 tháng qua</h6>
                    <div class="row align-items-center">
                        <div class="col-7 pr-0"><div style="height: 150px;"><canvas id="trendComboChart"></canvas></div></div>
                        <div class="col-5 text-center pl-0">
                            <p class="text-muted mb-1" style="font-size: 0.7rem;">So với tháng trước</p>
                            <h2 class="fw-bold mb-0" id="fluctuationRate">--%</h2>
                        </div>
                    </div>
                    <div class="text-end mt-2"><small class="text-muted" style="font-size: 0.65rem;">Cập nhật: <span id="currentTime"></span></small></div>
                </div>

                <div class="card border-0 rounded-4 shadow-sm mb-4 p-3 bg-white">
                    <h6 class="fw-bold mb-3">Phân bổ ngân sách chi tiêu</h6>
                    <div id="budgetAllocationList" class="d-flex flex-column gap-3"></div>
                </div>

                <div class="card border-0 rounded-4 shadow-sm p-3 bg-white" style="border-left: 5px solid #0d6efd !important;">
                    <h6 class="fw-bold text-primary mb-2"><i class="bi bi-lightbulb-fill me-1"></i> Đề xuất quản lý</h6>
                    <p class="small mb-0 text-dark" id="aiProposalText">Đang phân tích...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="manualModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 24px;">
            <div class="modal-header border-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Thêm giao dịch mới</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form action="/dashboard/input/manual" method="POST">
                    <input type="hidden" name="lat" id="latInput">
                    <input type="hidden" name="lng" id="lngInput">
                    <input type="hidden" name="billImageUrl" id="billImageUrlInput">
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Số tiền (VNĐ)</label>
                        <input type="number" name="soTien" class="form-control border-0 bg-light py-2" required>
                    </div>
                    
                    <div class="mb-3 position-relative">
                        <label class="form-label small fw-bold text-muted">Tên địa điểm / Quán ăn</label>
                        <div class="input-group">
                            <input type="text" name="tenQuan" id="searchInput" class="form-control border-0 bg-light py-2" placeholder="Ví dụ: Siêu thị Mega">
                            <button class="btn btn-primary fw-bold" type="button" id="btnSearchMap"><i class="bi bi-search"></i> Tìm Map</button>
                        </div>
                        <ul id="searchResults" class="list-group position-absolute w-100 shadow mt-1" style="z-index: 1050; display: none; max-height: 200px; overflow-y: auto;"></ul>
                        
                        <div class="text-end mt-2">
                            <a href="#" id="btnToggleMiniMap" class="small text-decoration-none text-success fw-bold"><i class="bi bi-geo-alt"></i> Chọn trực tiếp trên bản đồ</a>
                        </div>
                        <div id="miniMapContainer" style="display: none; height: 200px; border-radius: 12px; margin-top: 10px; z-index: 1;" class="border shadow-sm"></div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Hạng mục</label>
                            <select name="hangMuc" class="form-select border-0 bg-light"><option value="Ăn uống">🍜 Ăn uống</option><option value="Di chuyển">🚗 Di chuyển</option><option value="Mua sắm">🛍️ Mua sắm</option><option value="Giải trí">🎮 Giải trí</option><option value="Khác">⚙️ Khác</option></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Loại</label>
                            <select name="loai" class="form-select border-0 bg-light"><option value="chi">Chi tiêu (-)</option><option value="thu">Thu nhập (+)</option></select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Ghi chú</label>
                        <input type="text" name="ghiChu" class="form-control border-0 bg-light py-2" placeholder="Ný tiêu vào việc gì thế?">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill">LƯU GIAO DỊCH</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="voiceModal" data-bs-backdrop="static" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%); color: white;">
            <div class="modal-body text-center p-5">
                <div class="mic-container mb-4"><div class="pulse-ring"></div><i class="bi bi-mic-fill display-1"></i></div>
                <h5 class="fw-bold mb-3">Đang lắng nghe bạn...</h5>
                <div class="transcript-box p-3 bg-white bg-opacity-10 rounded-4" style="min-height: 80px;"><p id="live-text" class="mb-0 fs-5 fst-italic opacity-75">Hãy nói gì đó...</p></div>
                <button type="button" class="btn btn-link text-white mt-4 text-decoration-none" data-bs-dismiss="modal">Hủy bỏ</button>
            </div>
        </div>
    </div>
</div>

<script>
    window.DASHBOARD_DATA = {
        tongThu: <%= typeof tongThuNhap !== 'undefined' ? tongThuNhap : 0 %>,
        tongChi: <%= typeof tongChiTieu !== 'undefined' ? tongChiTieu : 0 %>,
        chartLabels: <%- JSON.stringify(typeof chartData !== 'undefined' ? chartData.labels : []) %>,
        chartValues: <%- JSON.stringify(typeof chartData !== 'undefined' ? chartData.values : []) %>,
        mapData: <%- JSON.stringify(typeof mapData !== 'undefined' ? mapData : []) %>
    };
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/dashboard.js"></script>

<%- include('../partials/footer') %>