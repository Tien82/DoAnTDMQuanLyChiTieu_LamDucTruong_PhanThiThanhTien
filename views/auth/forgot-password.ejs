<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu - SmartSpend</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card border-0 shadow-lg p-4" style="border-radius: 20px;">
                    <div class="text-center mb-4">
                        <h4 class="fw-bold">Khôi phục mật khẩu</h4>
                        <p class="text-muted small">Nhập tên đăng nhập để đặt mật khẩu mới</p>
                    </div>
                    <form action="/auth/forgot-password" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">TÊN ĐĂNG NHẬP</label>
                            <input type="text" name="tenDangNhap" class="form-control border-0 bg-light py-2" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">MẬT KHẨU MỚI</label>
                            <input type="password" name="newPassword" class="form-control border-0 bg-light py-2" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill">ĐỔI MẬT KHẨU</button>
                        <div class="text-center mt-3">
                            <a href="/auth/login" class="text-decoration-none small text-secondary">Quay lại đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>