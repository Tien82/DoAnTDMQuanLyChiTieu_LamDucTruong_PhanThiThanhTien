<%- include('../partials/header') %>

<div class="main-content py-5" style="background-color: #f8f9fa; min-height: 100vh;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold m-0">
                <i class="bi bi-shield-lock-fill text-primary me-2"></i>Hệ thống Quản trị SmartSpend
            </h2>
            </div>
        
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-white" style="background: linear-gradient(45deg, #0d6efd, #0dcaf0);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-white-50 fw-bold">TỔNG NGƯỜI DÙNG</small>
                            <h2 class="fw-bold mt-1 mb-0"><%= stats.totalUsers %></h2>
                        </div>
                        <i class="bi bi-people fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-white" style="background: linear-gradient(45deg, #198754, #20c997);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-white-50 fw-bold">GIAO DỊCH HỆ THỐNG</small>
                            <h2 class="fw-bold mt-1 mb-0"><%= stats.totalTransactions %></h2>
                        </div>
                        <i class="bi bi-arrow-left-right fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-white" style="background: linear-gradient(45deg, #dc3545, #fd7e14);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-white-50 fw-bold">TỔNG DÒNG TIỀN (VND)</small>
                            <h2 class="fw-bold mt-1 mb-0"><%= stats.systemVolume.toLocaleString() %>đ</h2>
                        </div>
                        <i class="bi bi-currency-exchange fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold m-0 text-dark">Danh sách chi tiêu toàn hệ thống</h5>
                
                <form action="/dashboard/admin/dashboard" method="GET" class="input-group" style="width: 300px;">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" class="form-control bg-light border-0 small" 
                           placeholder="Tìm tên, hạng mục..." value="<%= searchQuery %>">
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="px-4 py-3 border-0">Người dùng</th>
                            <th class="py-3 border-0">Hạng mục</th>
                            <th class="py-3 border-0 text-end">Số tiền</th>
                            <th class="py-3 border-0 text-center">Ngày thực hiện</th>
                            <th class="py-3 border-0">Phương thức</th>
                            <th class="py-3 border-0">Ghi chú</th>
                            <th class="px-4 py-3 border-0 text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (allExpenses.length > 0) { %>
                            <% allExpenses.forEach(item => { %>
                                <tr class="border-bottom">
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <img src="https://ui-avatars.com/api/?name=<%= item.user ? (item.user.hoVaTen || item.user.tenDangNhap) : 'Guest' %>&background=random&color=fff&size=32" class="rounded-circle me-2">
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold small text-dark"><%= item.user ? (item.user.hoVaTen || item.user.tenDangNhap) : 'Bạn ẩn danh' %></span>
                                                <span class="text-muted" style="font-size: 0.7rem;"><%= item.user ? item.user.role : 'user' %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-info-subtle text-info px-3"><%= item.hangMuc %></span>
                                    </td>
                                    <td class="text-end fw-bold">
                                        <span class="<%= item.soTien < 0 ? 'text-danger' : 'text-success' %>">
                                            <%= item.soTien.toLocaleString() %>đ
                                        </span>
                                    </td>
                                    <td class="text-center small text-secondary">
                                        <%= new Date(item.ngayGiaoDich).toLocaleDateString('vi-VN') %>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill border py-1 px-2 <%= item.phuongThucNhap === 'voice' ? 'bg-primary-subtle text-primary' : (item.phuongThucNhap === 'ocr' ? 'bg-success-subtle text-success' : 'bg-light text-muted') %>" style="font-size: 0.65rem;">
                                            <% if (item.phuongThucNhap === 'voice') { %>
                                                <i class="bi bi-mic-fill me-1"></i> Giọng nói
                                            <% } else if (item.phuongThucNhap === 'ocr') { %>
                                                <i class="bi bi-camera-fill me-1"></i> Quét bill
                                            <% } else { %>
                                                <i class="bi bi-pencil-square me-1"></i> Nhập tay
                                            <% } %>
                                        </span>
                                    </td>
                                    <td class="small text-muted" title="<%= item.ghiChu %>" style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <%= item.ghiChu %>
                                    </td>
                                    <td class="px-4 text-center">
                                        <button class="btn btn-sm btn-light rounded-circle shadow-sm"><i class="bi bi-eye text-primary"></i></button>
                                        <button class="btn btn-sm btn-light rounded-circle shadow-sm ms-1"><i class="bi bi-trash text-danger"></i></button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy giao dịch nào khớp với từ khóa.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="card-footer bg-white border-0 p-4">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                            <a class="page-link border-0 bg-light rounded-circle me-2" 
                               href="?page=<%= currentPage - 1 %>&q=<%= searchQuery %>">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link border-0 rounded-circle me-2 shadow-sm" 
                                   href="?page=<%= i %>&q=<%= searchQuery %>"><%= i %></a>
                            </li>
                        <% } %>

                        <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                            <a class="page-link border-0 bg-light rounded-circle" 
                               href="?page=<%= currentPage + 1 %>&q=<%= searchQuery %>">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>